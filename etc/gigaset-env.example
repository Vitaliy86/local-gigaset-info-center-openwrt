# Gigaset Info Center Environment Configuration
# Place this file in /etc/gigaset-info-center/env.conf
# Edit the values below according to your setup

# OpenWeatherMap API key (get free account at https://openweathermap.org)
OPENWEATHERMAP_API_KEY="your_api_key_here"

# City name for display
CITY="Berlin"

# Coordinates for weather data
LATITUDE=52.52437
LONGITUDE=13.41053

# Base URLs (do not change unless you host differently)
BASE_URL="http://info.gigaset.net/info"
ICON_BASE_URL="http://gigaset.net/img"
PROXY_BASE_URL="http://gigaset.net"

# Show weather icons (true/false)
SHOW_ICONS="true"
